@page "/reports"

<PageTitle>Reports</PageTitle>
<h1>Delivery Reports</h1>

<div class="content">
    <h2>Performance Metrics</h2>
    <div class="shipment-stats">
        <div class="stat-card">
            <div class="stat-value">@_onTimeDeliveryRate%</div>
            <div class="stat-label">On-Time Delivery Rate</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@_avgDeliveryTime days</div>
            <div class="stat-label">Average Delivery Time</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@_customerSatisfaction/5</div>
            <div class="stat-label">Customer Satisfaction</div>
        </div>
    </div>

    <h2>Monthly Summary</h2>
    <RadzenDataGrid Data="@_monthlyStats" TItem="MonthlyStat" AllowSorting="true">
        <Columns>
            <RadzenDataGridColumn TItem="MonthlyStat" Property="Month" Title="Month" />
            <RadzenDataGridColumn TItem="MonthlyStat" Property="TotalShipments" Title="Total Shipments" />
            <RadzenDataGridColumn TItem="MonthlyStat" Property="Revenue" Title="Revenue" FormatString="{0:C}" />
            <RadzenDataGridColumn TItem="MonthlyStat" Property="OnTimeRate" Title="On-Time Rate" FormatString="{0}%" />
        </Columns>
    </RadzenDataGrid>

    <div class="mt-4">
        <RadzenButton Text="Export to PDF" Icon="picture_as_pdf" ButtonStyle="ButtonStyle.Primary" />
        <RadzenButton Text="Export to Excel" Icon="table_chart" ButtonStyle="ButtonStyle.Success" Class="ms-2" />
    </div>
</div>

@code {
    private int _onTimeDeliveryRate = 94;
    private double _avgDeliveryTime = 2.3;
    private double _customerSatisfaction = 4.6;
    private List<MonthlyStat> _monthlyStats = new();

    protected override void OnInitialized()
    {
        var months = new[] { "January", "February", "March", "April", "May", "June" };
        _monthlyStats = months.Select((month, index) => new MonthlyStat
        {
            Month = month,
            TotalShipments = Random.Shared.Next(800, 1200),
            Revenue = Random.Shared.Next(50000, 80000),
            OnTimeRate = Random.Shared.Next(90, 98)
        }).ToList();
    }

    private record MonthlyStat
    {
        public string Month { get; init; } = string.Empty;
        public int TotalShipments { get; init; }
        public decimal Revenue { get; init; }
        public int OnTimeRate { get; init; }
    }
}