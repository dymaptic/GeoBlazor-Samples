@page "/settings"

<PageTitle>Settings</PageTitle>
<h1>Settings</h1>

<div class="content">
    <RadzenTabs>
        <Tabs>
            <RadzenTabsItem Text="General">
                <h3>General Settings</h3>
                <div class="mb-3">
                    <RadzenLabel Text="Company Name" />
                    <RadzenTextBox @bind-Value="_companyName" Class="w-100" />
                </div>
                <div class="mb-3">
                    <RadzenLabel Text="Default Warehouse Location" />
                    <RadzenTextBox @bind-Value="_warehouseLocation" Class="w-100" />
                </div>
                <div class="mb-3">
                    <RadzenCheckBox @bind-Value="_enableNotifications" />
                    <RadzenLabel Text="Enable Email Notifications" Class="ms-2" />
                </div>
            </RadzenTabsItem>
            
            <RadzenTabsItem Text="Map Settings">
                <h3>Map Configuration</h3>
                <div class="mb-3">
                    <RadzenCheckBox @bind-Value="_showTrafficByDefault" />
                    <RadzenLabel Text="Show Traffic Layer by Default" Class="ms-2" />
                </div>
                <div class="mb-3">
                    <RadzenCheckBox @bind-Value="_showWeatherByDefault" />
                    <RadzenLabel Text="Show Weather Layer by Default" Class="ms-2" />
                </div>
                <div class="mb-3">
                    <RadzenLabel Text="Default Map Zoom Level" />
                    <RadzenNumeric @bind-Value="_defaultZoom" Min="1" Max="20" />
                </div>
            </RadzenTabsItem>
            
            <RadzenTabsItem Text="API Keys">
                <h3>API Configuration</h3>
                <div class="mb-3">
                    <RadzenLabel Text="ArcGIS API Key" />
                    <RadzenTextBox @bind-Value="_arcgisApiKey" Class="w-100" Type="password" />
                </div>
                <div class="mb-3">
                    <RadzenLabel Text="Email Service API Key" />
                    <RadzenTextBox @bind-Value="_emailApiKey" Class="w-100" Type="password" />
                </div>
            </RadzenTabsItem>
        </Tabs>
    </RadzenTabs>
    
    <div class="mt-4">
        <RadzenButton Text="Save Settings" Icon="save" ButtonStyle="ButtonStyle.Primary" Click="SaveSettings" />
        <RadzenButton Text="Cancel" Icon="cancel" ButtonStyle="ButtonStyle.Light" Class="ms-2" />
    </div>
</div>

@code {
    private string _companyName = "LogiTrack Global Shipping";
    private string _warehouseLocation = "Chicago, IL";
    private bool _enableNotifications = true;
    private bool _showTrafficByDefault = false;
    private bool _showWeatherByDefault = false;
    private int _defaultZoom = 10;
    private string _arcgisApiKey = "";
    private string _emailApiKey = "";

    private void SaveSettings()
    {
        // In a real app, this would save to configuration
        Console.WriteLine("Settings saved!");
    }
}