@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu/>
    </div>

    <main>
        <div class="top-row">
            <div class="company-header">
                <img src="BlazingShipments.png" alt="Blazing Shipments" class="company-logo" />
                <div>
                    <small class="company-tagline">Global Shipping Solutions</small>
                </div>
            </div>
            <div class="top-links">
                <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">Documentation</a>
                <a href="#" class="btn btn-sm btn-primary">Support</a>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
