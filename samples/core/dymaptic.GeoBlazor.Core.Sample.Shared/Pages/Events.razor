    </div>
</Accordion>
<Accordion Title="Key/Mouse Events">
    <div class="spaced-row">
        <div class="form-group">
            <label>
                Key Down:
            </label>
            <div class="response-area">
                <b>@((MarkupString)_keyDownJson)</b>
            </div>
        </div>
        <div class="form-group">
            <label>
                Key Up:
            </label>
            <div class="response-area">
                <b>@((MarkupString)_keyUpJson)</b>
