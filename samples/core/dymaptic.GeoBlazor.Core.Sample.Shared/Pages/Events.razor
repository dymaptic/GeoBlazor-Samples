@page "/events"
@inherits SamplePage
@using System.Text.Json.Serialization
@using Environment = System.Environment

<PageTitle>Events</PageTitle>
<h1>Events</h1>
<p class="instructions">
    Sample demonstrates simple event listeners attached to the MapView.
</p>

<Accordion Title="Click/Drag/Focus Events">
    <div class="spaced-row">
        <div class="form-group">
            <label>
                Click:
            </label>
            <div class="response-area">
                <b>@((MarkupString)_clickJson)</b>
            </div>
        </div>
        <div class="form-group">
            <label>
                Double Click:
            </label>
            <div class="response-area">
                <b>@((MarkupString)_doubleClickJson)</b>
            </div>
        </div>
        <div class="form-group">
            <label>
                Hold:
            </label>
            <div class="response-area">
                <b>@((MarkupString)_holdJson)</b>
            </div>
        </div>
    </div>
    <div class="spaced-row">
        <div class="form-group">
            <label>
                Drag:
            </label>
            <div class="response-area">
                <b>@((MarkupString)_dragJson)</b>
            </div>
        </div>
        <div class="form-group">
            <label>
                Blur:
            </label>
            <div class="response-area">
                <b>@((MarkupString)_blurJson)</b>
            </div>
        </div>
        <div class="form-group">
            <label>
                Focus:
            </label>
            <div class="response-area">
                <b>@((MarkupString)_focusJson)</b>
            </div>
        </div>
    </div>
</Accordion>
<Accordion Title="Pointer Events">
    <div class="spaced-row">
        <div class="form-group">
            <label>
                Pointer Down:
            </label>
            <div class="response-area">
                <b>@((MarkupString)_pointerDownJson)</b>
            </div>
        </div>
        <div class="form-group">
            <label>
                Pointer Up:
            </label>
            <div class="response-area">
                <b>@((MarkupString)_pointerUpJson)</b>
            </div>
        </div>
        <div class="form-group">
            <label>
                Pointer Enter:
            </label>
            <div class="response-area">
                <b>@((MarkupString)_pointerEnterJson)</b>
            </div>
        </div>
    </div>
    <div class="spaced-row">
        <div class="form-group">
            <label>
                Pointer Leave:
            </label>
            <div class="response-area">
                <b>@((MarkupString)_pointerLeaveJson)</b>
            </div>
        </div>
        <div class="form-group">
            <label>
                Pointer Move:
            </label>
            <div class="response-area">
