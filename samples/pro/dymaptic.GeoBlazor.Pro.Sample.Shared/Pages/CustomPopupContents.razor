@page "/custom-popup-content"

<PageTitle>Custom Popup Content</PageTitle>
<h1>Custom Popup Content</h1>

<div class="links-div">
    <a class="btn btn-secondary" target="_blank" href="https://developers.arcgis.com/javascript/latest/sample-code/popup-customcontent/">ArcGIS API for JavaScript</a>
    <a class="btn btn-primary" target="_blank" href="https://services.arcgis.com/V6ZHFr6zdgNZuVG0/arcgis/rest/services/OverlaySchools/FeatureServer/0">Private and Public US Schools</a>
</div>
<p class="instructions">
    This sample demonstrates how to work with custom content elements within the PopupTemplate's content. 
    There are five types of popup elements: <code>FieldsContent</code>, <code>MediaContent</code>, <code>TextContent</code>, <code>AttachmentsContent</code>, and <code>CustomContent</code>. 
    The <code>CustomContent</code>'s value is set via the <code>CreatorFunction</code> property, or by providing child content inside the component. 
    The <code>CreatorFunction</code> property has an event parameter with the selected <code>Feature</code> graphic, and returns
    an HTML string value to be rendered. The child content of <code>CustomContent</code> can be either HTML content or a GeoBlazor <code>Widget</code>.
    In this sample, we combine three different types of custom content elements: an image, a <code>SearchWidget</code>, 
    and a <code>CreatorFunction</code> that parses the selected graphic for data.
</p>

<MapView @ref="_mapView"
         Longitude="-98" Latitude="38.5" 
         Zoom="4" Class="map-view">
    <Map>
        <Basemap>
            <BasemapStyle Name="BasemapStyleName.ArcgisTopographic" />
        </Basemap>
        <FeatureLayer Url="https://services.arcgis.com/V6ZHFr6zdgNZuVG0/arcgis/rest/services/OverlaySchools/FeatureServer/0"
                      OutFields="@(["*"])"
                      Title="Private and Public schools in the US"
                      @ref="_schoolsLayer"
                      PopupEnabled="true">
            <PopupTemplate OutFields="@( ["*"])"
                           Title="State: {state_name}">
                <CustomContent>
                    <img src="@_logoUrl"
                         width="150"
                         alt="GeoBlazor Logo" />
                </CustomContent>
                <CustomContent>
                    <SearchWidget IncludeDefaultSources="false"
                                  LocationEnabled="false"
                                  PopupEnabled="true"
                                  SearchAllEnabled="false"
                                  SuggestionsEnabled="true"
                                  OnSelectResult="OnSelectResult">
                        <LayerSearchSource LayerId="_schoolsLayer?.Id"
                                           SearchFields="@( ["state_name"])"
                                           DisplayField="state_name"
                                           ExactMatch="false"
                                           OutFields="@( ["*"])"
                                           Name="State name"
                                           Placeholder="Search by state" />
                    </SearchWidget>
                </CustomContent>
                <CustomContent CreatorFunction="@GenerateContent"
                                    OutFields="@( ["*"])" />
            </PopupTemplate>
        </FeatureLayer>
    </Map>
    <PopupWidget @ref="_popupWidget" 
                 DefaultPopupTemplateEnabled="false"
                 DockEnabled="true">
        <PopupDockOptions ButtonEnabled="false"
                          BreakPoint="@(new Breakpoint(false))" />
    </PopupWidget>
</MapView>