@page "/routes"
@inherits SamplePage

<PageTitle>Routes</PageTitle>
<h1>Routes</h1>

<p class="instructions">
    Click on two points on the map to designate starting point and destination. You will see a popup with
    driving directions!
</p>
<button @onclick="Clear" class="btn btn-danger">Clear</button>
<MapView Longitude="-117.195"
         Latitude="34.057"
         Zoom="13"
         Class="map-view"
         OnClick="OnClick">
    <Map>
        <Basemap>
            <PortalItem PortalItemId="4f2e99ba65e34bb8af49733d9778fb8e" />
        </Basemap>
        <GraphicsLayer @ref="_routeLayer" />
    </Map>
    <CustomOverlay Position="OverlayPosition.TopRight">
        <ol id="directions-widget" class="esri-widget esri-widget--panel esri-directions__scroller">
            @foreach (DirectionsFeatureSet directionSet in _directions)
            {
                if (directionSet.Features is null) continue;
                foreach (Graphic direction in directionSet.Features)
                {
                    <li>@(direction.Attributes["text"]) (@(double.Parse(direction.Attributes["length"]!.ToString()!).ToString("F")) miles)</li>    
                }
            }
        </ol>
    </CustomOverlay>
</MapView>

@code {

    public override List<NavMenu.PageLink> PageLinks =>
    [
        new("https://developers.arcgis.com/javascript/latest/sample-code/route/", "ArcGIS Maps SDK for JavaScript"),
        new("https://www.arcgis.com/home/item.html?id=4f2e99ba65e34bb8af49733d9778fb8e", "Human Geography Dark BaseMap")
    ];

    public override string Description =>
        "This GeoBlazor Pro sample, written in Blazor for .NET developers, demonstrates routing and turn-by-turn " +
        "directions from the ArcGIS Maps SDK for JavaScript exposed through GeoBlazor Pro's RouteService together " +
        "with the GraphicsLayer and CustomOverlay Razor components. The page shows a 2D dark human-geography basemap " +
        "centered on Redlands, California, with a Clear button positioned above the map. The user clicks two or " +
        "more locations on the map; each click drops a white cross stop marker, and once at least two stops exist " +
        "the sample calls RouteService.Solve against the world routing service and renders the resulting route as " +
        "a translucent blue polyline. A directions panel pinned in the upper-right corner of the map lists each " +
        "maneuver with its distance in miles, and the Clear button removes all stops, the route, and the directions. " +
        "The sample is intended to demonstrate point-and-click route solving and step-by-step driving directions " +
        "with the ArcGIS World Route service.";

    [Inject]
    public required RouteService RouteService { get; set; }
    
    private async Task OnClick(ClickEvent clickEvent)
    {
        Graphic stop = new(clickEvent.MapPoint, _stopSymbol);
        await _routeLayer!.Add(stop);
        List<Graphic> stops = _routeParameters.FeatureSetStops!.Features!.ToList();
        stops.Add(stop);
        _routeParameters.FeatureSetStops = _routeParameters.FeatureSetStops with {Features = stops.ToArray()};

        if (_routeParameters.FeatureSetStops.Features?.Count >= 2)
        {
            RouteSolveResult result = await RouteService.Solve(_routeUrl, _routeParameters);
            await ShowRoute(result);
        }
    }
    
    private async Task ShowRoute(RouteSolveResult result)
    {
        Graphic? routeGraphic = result.RouteResults?.FirstOrDefault()?.Route;

        if (routeGraphic is null) return;
        await routeGraphic.SetSymbol(_routeSymbol);
        await _routeLayer!.Add(routeGraphic);
        _directions = result.RouteResults!.Select(r => r.Directions!).ToArray();
    }

    private async Task Clear()
    {
        _directions = [];
        _routeParameters.FeatureSetStops = _routeParameters.FeatureSetStops! with {Features = []};
        await _routeLayer!.Clear();
    }

    private GraphicsLayer? _routeLayer;
    private readonly SimpleMarkerSymbol _stopSymbol = new(new Outline(new MapColor("white"), width: 5), new MapColor("white"), 
        style: SimpleMarkerSymbolStyle.Cross, size: 15);
    private readonly SimpleLineSymbol _routeSymbol = new(new MapColor(0, 0, 255, 0.5), 5);
    private readonly RouteParameters _routeParameters = new()
    {
        FeatureSetStops = new FeatureSet
        {
            Features = []
        },
        OutSpatialReference = new SpatialReference(3857),
        ReturnDirections = true
    };
    
    private readonly string _routeUrl = "https://route-api.arcgis.com/arcgis/rest/services/World/Route/NAServer/Route_World";
    private DirectionsFeatureSet[] _directions = [];

}