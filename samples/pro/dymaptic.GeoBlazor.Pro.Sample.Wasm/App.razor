<Router AppAssembly="@typeof(App).Assembly"
        AdditionalAssemblies="@([ typeof(ProMainLayout).Assembly, typeof(Navigation).Assembly ])">
    <Found Context="routeData">
        <CascadingValue Name="PageRouteData" Value="routeData">
            <RouteView RouteData="@routeData" DefaultLayout="@typeof(ProMainLayout)" />
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </CascadingValue>
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="@typeof(ProMainLayout)">
            <p role="alert">Sorry, there's nothing at this address.</p>
        </LayoutView>
    </NotFound>
</Router>