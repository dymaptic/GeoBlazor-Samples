<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:blazor="clr-namespace:Microsoft.AspNetCore.Components.WebView.Maui;assembly=Microsoft.AspNetCore.Components.WebView.Maui"
             xmlns:razor="clr-namespace:FieldAssetInspector.Razor;assembly=FieldAssetInspector.Razor"
             x:Class="FieldAssetInspector.MauiControls.EmbeddedMapView">

    <blazor:BlazorWebView HostPage="wwwroot/index.html">
        <blazor:BlazorWebView.RootComponents>
            <blazor:RootComponent Selector="#app"
                                  ComponentType="{x:Type razor:MapPage}" />
        </blazor:BlazorWebView.RootComponents>
    </blazor:BlazorWebView>

</ContentView>
